---
layout: none
permalink: /search_index.json
---
[
{% assign all_items = "" | split: "" %}
{% assign all_items = all_items | concat: site.articles %}
{% assign all_items = all_items | concat: site.letters %}
{% assign all_items = all_items | concat: site.reviews %}
{% assign all_items = all_items | concat: site.reflections %}
{% assign all_items = all_items | concat: site.calls %}
{% assign all_items = all_items | concat: site.fiction_stories %}
{% assign all_items = all_items | concat: site.poetry %}
{% assign all_items = all_items | concat: site.what_i_saw %}
{% assign all_items = all_items | concat: site.events %}
{% assign all_items = all_items | concat: site.diary %}
{% assign sorted = all_items | sort: "date" | reverse %}
{% for item in sorted %}
  {
    "title_en": {{ item.title_en | jsonify }},
    "title_ur": {{ item.title_ur | jsonify }},
    "url_en": "{{ site.baseurl }}/en{{ item.url }}",
    "url_ur": "{{ site.baseurl }}/ur{{ item.url }}",
    "date": "{{ item.date | date: '%Y-%m-%d' }}",
    "type_en": "{% if site.articles contains item %}Article{% elsif site.letters contains item %}Letter{% elsif site.diary contains item %}Teaching Diary{% elsif site.reviews contains item %}Review{% elsif site.reflections contains item %}Reflection{% elsif site.fiction_stories contains item %}Fiction & Stories{% elsif site.poetry contains item %}Poetry{% elsif site.what_i_saw contains item %}What I Saw{% elsif site.events contains item %}Event{% else %}Call{% endif %}",
    "type_ur": "{% if site.articles contains item %}مضمون{% elsif site.letters contains item %}خط{% elsif site.diary contains item %}تدریسی ڈائری{% elsif site.reviews contains item %}جائزہ{% elsif site.reflections contains item %}عکاسی{% elsif site.fiction_stories contains item %}افسانہ اور کہانیاں{% elsif site.poetry contains item %}شاعری{% elsif site.what_i_saw contains item %}میں نے دیکھا{% elsif site.events contains item %}تقریب{% else %}دعوت{% endif %}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
